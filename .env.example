# Resend — replace with your real API key from https://resend.com (e.g. re_xxxxxxxxx)
RESEND_API_KEY=
# Optional: Resend Audience ID (from dashboard). Leave empty or omit if you don't use an audience.
# RESEND_WAITLIST_AUDIENCE_ID=
# Optional: "From" address for emails (must be verified in Resend; default: onboarding@resend.dev)
RESEND_FROM_EMAIL=
# Optional: for testing POST /api/test-email without sending a body
RESEND_TEST_TO=
